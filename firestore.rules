// Firestore security rules for the 2026 U.S. Open pool.
//
// Deploy via Firebase Console (Firestore → Rules → paste + Publish)
// or via CLI: `firebase deploy --only firestore:rules`
//
// Trust model: Firebase Email Link (passwordless) auth gives each verified email
// a stable auth.uid. Display-name ownership is recorded in pins/{name}.uid. All
// privileged writes require request.auth.uid == pins/{name}.uid for the relevant
// name. Identity comes from Firebase auth tied to a verified email — there are
// no PINs stored anywhere.
//
// Anonymous Auth must be DISABLED in the Firebase Console — these rules require
// request.auth != null, and Anonymous Auth would let unverified visitors satisfy
// that check while still being unidentifiable.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Name claims (one per display name, bound to a Firebase auth UID) ────
    // First-come-first-serve. Once claimed, never modified.
    match /pins/{name} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
                    && request.resource.data.uid is string
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Entries: write-once, locked-on-submit, owned via pins/{name}.uid ────
    // An entry can be CREATED until first tee (2026-06-18 UTC) AND only by the
    // Firebase auth user who owns the matching pins/{name} doc. Updates/deletes
    // are denied at the rule layer — submissions are final.
    match /entries/{name} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.time < timestamp.date(2026, 6, 18)
                    && exists(/databases/$(database)/documents/pins/$(name))
                    && get(/databases/$(database)/documents/pins/$(name)).data.uid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name == name
                    && request.resource.data.winner is string
                    && request.resource.data.alternate is string
                    && request.resource.data.picks is list
                    && request.resource.data.picks.size() == 21;
      allow update, delete: if false;
    }

    // ── Trash talk messages ────────────────────────────────────────────────
    // Doc ID is restricted to a safe charset so the client never has to worry
    // about it leaking into onclick handlers. Updates are limited to the
    // reactions field — text/name/timestamp are immutable once written.
    match /messages/{msgId} {
      allow read: if true;
      allow create: if request.auth != null
                    && msgId.matches('^[A-Za-z0-9_-]+$')
                    && request.resource.data.uid is string
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 280;
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
      allow delete: if false;
    }
  }
}
